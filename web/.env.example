# JWT — AetherGate .NET 서버와 동일한 값을 사용해야 함
JWT_SECRET=change-me-to-a-strong-secret
JWT_ISSUER=AetherGate
JWT_AUDIENCE=AetherGateClient
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aethergate

# Redis
REDIS_URL=redis://localhost:6379

# 서버 베이스 URL (OAuth 콜백 URI에 사용)
BASE_URL=http://localhost:8000

# Guest 모드 활성화 여부 (true/false)
GUEST_ENABLED=true

# OAuth (앱 등록 후 설정)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
